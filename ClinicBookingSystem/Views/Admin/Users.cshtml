@model List<ClinicBookingSystem.Models.AppUser>

<h2>All Users</h2>

<table class="table">
    <thead>
        <tr>
            <th>Email</th>
            <th>User ID</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Email</td>
                <td>@user.Id</td>
            </tr>
        }
    </tbody>
</table>