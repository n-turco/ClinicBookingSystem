@model ClinicBookingSystem.Models.Appointment

@{
    ViewData["Title"] = "Confirm Booking";
}

<h1>Confirm Booking</h1>

<hr />

<div>
    <h4>Appointment Details</h4>

    <p><strong>Start:</strong> @Model.StartTime</p>
    <p><strong>End:</strong> @Model.EndTime</p>
</div>

<form asp-action="CreateConfirmed" method="post">
    <input type="hidden" name="id" value="@Model.Id" />

    <button type="submit" class="btn btn-primary">
        Confirm Booking
    </button>
</form>

<div class="mt-2">
    <a asp-controller="Appointments" asp-action="Index">Back to Appointments</a>
</div>