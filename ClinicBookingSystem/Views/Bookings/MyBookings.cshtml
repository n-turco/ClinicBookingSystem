@model List<ClinicBookingSystem.Models.Booking>

@{
    ViewData["Title"] = "My Bookings";
}

<h1>My Bookings</h1>

<table class="table">
    <thead>
        <tr>
            <th>Start Time</th>
            <th>End Time</th>
            <th>Booked At</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model ?? new List<ClinicBookingSystem.Models.Booking>())
        {
            <tr>
                @if (User?.IsInRole("Admin") ?? false)
                {
                    <td>@item?.User?.UserName</td>
                }
                <td>@item?.Appointment?.StartTime</td>
                <td>@item?.Appointment?.EndTime</td>
                <td>@item?.CreatedAt</td>
                <td>
                    <a asp-action="Delete" asp-route-id="@item?.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>