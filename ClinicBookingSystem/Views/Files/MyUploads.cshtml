@model List<ClinicBookingSystem.Models.UploadedFile>

<h2>My Files</h2>

<table class="table">
    @foreach (var file in Model)
    {
        <tr>
            <td>@file.FileName</td>
            <td>@file.UploadedAt</td>
    <td>
                <a asp-controller="Files" asp-action="ViewDocument" asp-route-id="@file.Id" target="_blank">View</a>
            </td>
        </tr>
    }
</table>